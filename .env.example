# Django Delights - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# Django Core Settings
# =============================================================================

# SECURITY WARNING: Generate a new secret key for production!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-in-production

# Debug mode - NEVER set to True in production
DEBUG=True

# Allowed hosts - comma separated list
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database Configuration
# =============================================================================

# Database URL (supports SQLite for dev, PostgreSQL for prod)
# SQLite: sqlite:///db.sqlite3
# PostgreSQL: postgres://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Or use individual PostgreSQL settings (for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=django_delights
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# Business Configuration
# =============================================================================

# Global margin for pricing (default: 0.20 = 20%)
GLOBAL_MARGIN=0.20

# Low stock alert threshold (default: 10 units)
LOW_STOCK_THRESHOLD=10

# =============================================================================
# JWT Authentication (for API)
# =============================================================================

# Access token lifetime in minutes (default: 60)
JWT_ACCESS_TOKEN_LIFETIME=60

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_LIFETIME=7

# =============================================================================
# CORS Settings (for API consumers)
# =============================================================================

# Allowed origins for CORS - comma separated
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourfrontend.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Email Configuration (optional - for password reset, etc.)
# =============================================================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# =============================================================================
# Production Settings
# =============================================================================

# Static files root (for collectstatic)
# STATIC_ROOT=/var/www/static

# Media files root (for user uploads)
# MEDIA_ROOT=/var/www/media

# Secure cookies (set to True in production with HTTPS)
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS settings (for HTTPS enforcement)
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Railway Deployment (if using Railway)
# =============================================================================

# Railway provides these automatically:
# RAILWAY_ENVIRONMENT
# PORT
